<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Material Components (M2) — jawne sp, bo ?attr/textAppearance* z M3 na tym theme jest puste / złe -->
    <style name="TextAppearance.Urbanfix.Headline" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textSize">30sp</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>
    <style name="TextAppearance.Urbanfix.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>
    <style name="TextAppearance.Urbanfix.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>
    <style name="TextAppearance.Urbanfix.BodySecondary" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">17sp</item>
        <item name="android:textColor">?android:attr/textColorSecondary</item>
        <item name="android:lineSpacingMultiplier">1.15</item>
    </style>
    <style name="TextAppearance.Urbanfix.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>
    <style name="TextAppearance.Urbanfix.Label" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">?android:attr/textColorSecondary</item>
    </style>
    <style name="TextAppearance.Urbanfix.Mono" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>
    <style name="TextAppearance.Urbanfix.InputHint" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">16sp</item>
    </style>
    <style name="TextAppearance.Urbanfix.Link" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

    <!-- Szczegóły zgłoszenia — jawne sp (M3 attrs na tym theme bywają zbyt małe) -->
    <style name="TextAppearance.Urbanfix.IssueDetailLabel" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">?android:attr/textColorSecondary</item>
    </style>
    <style name="TextAppearance.Urbanfix.IssueDetailValue" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">19sp</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>

    <style name="TextAppearance.Urbanfix.BottomNav.Active" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="TextAppearance.Urbanfix.BottomNav.Inactive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
