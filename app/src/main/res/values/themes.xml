<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Urbanfix" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Większa domyślna typografia (M2) -->
        <item name="textAppearanceBody1">@style/TextAppearance.Urbanfix.Body</item>
        <item name="textAppearanceBody2">@style/TextAppearance.Urbanfix.BodySecondary</item>
        <item name="textAppearanceSubtitle1">@style/TextAppearance.Urbanfix.Subtitle</item>
        <item name="textAppearanceCaption">@style/TextAppearance.Urbanfix.Label</item>
    </style>

    <style name="Widget.Urbanfix.BottomNavigationView" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@drawable/bg_bottom_nav</item>
        <item name="android:minHeight">64dp</item>
        <item name="elevation">10dp</item>
        <item name="itemIconTint">@color/bottom_nav_item_tint</item>
        <item name="itemTextColor">@color/bottom_nav_item_tint</item>
        <item name="itemRippleColor">@color/bottom_nav_ripple</item>
        <item name="itemIconSize">28dp</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.Urbanfix.BottomNav.Active</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.Urbanfix.BottomNav.Inactive</item>
    </style>

    <style name="Widget.Urbanfix.HomeIssueTile" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/home_issue_tile_corner_radius</item>
        <item name="cardElevation">@dimen/home_issue_tile_elevation</item>
        <item name="strokeWidth">@dimen/home_issue_tile_stroke_width</item>
        <item name="strokeColor">@color/home_tile_stroke</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="rippleColor">@color/bottom_nav_ripple</item>
    </style>
</resources>