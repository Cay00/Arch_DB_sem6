<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Urbanfix" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Większa domyślna typografia (M2) -->
        <item name="textAppearanceBody1">@style/TextAppearance.Urbanfix.Body</item>
        <item name="textAppearanceBody2">@style/TextAppearance.Urbanfix.BodySecondary</item>
        <item name="textAppearanceSubtitle1">@style/TextAppearance.Urbanfix.Subtitle</item>
        <item name="textAppearanceCaption">@style/TextAppearance.Urbanfix.Label</item>
    </style>
</resources>