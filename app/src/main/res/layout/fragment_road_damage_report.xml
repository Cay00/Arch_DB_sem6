<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingTop="4dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputLayoutIssueCategory"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/issue_hint_category"
            app:hintTextAppearance="@style/TextAppearance.Urbanfix.InputHint">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/editIssueCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:minHeight="52dp"
                android:textSize="18sp"
                tools:text="Drogi" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/issue_form_status_new"
            android:textAppearance="@style/TextAppearance.Urbanfix.BodySecondary" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputLayoutIssueUserIdentity"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="@string/issue_hint_user_id"
            app:hintTextAppearance="@style/TextAppearance.Urbanfix.InputHint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editIssueUserIdentity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:focusable="false"
                android:inputType="textEmailAddress"
                android:minHeight="52dp"
                android:textSize="18sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputLayoutIssueUserDisplayName"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/profile_name_label"
            app:hintTextAppearance="@style/TextAppearance.Urbanfix.InputHint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editIssueUserDisplayName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:focusable="false"
                android:inputType="textPersonName|textCapWords"
                android:minHeight="52dp"
                android:textSize="18sp"
                tools:text="Jan Kowalski" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputLayoutIssueTitle"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:hintTextAppearance="@style/TextAppearance.Urbanfix.InputHint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editIssueTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/issue_hint_title"
                android:minHeight="52dp"
                android:textSize="18sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputLayoutIssueDescription"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:hintTextAppearance="@style/TextAppearance.Urbanfix.InputHint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editIssueDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:hint="@string/issue_hint_description"
                android:inputType="textMultiLine"
                android:minLines="5"
                android:textSize="18sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputLayoutIssueLocation"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="@string/issue_hint_location"
            app:endIconMode="custom"
            app:endIconDrawable="@android:drawable/ic_menu_mylocation"
            app:endIconContentDescription="Zczytaj lokalizację"
            app:hintTextAppearance="@style/TextAppearance.Urbanfix.InputHint">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/editIssueLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPostalAddress"
                android:minHeight="52dp"
                android:textSize="18sp"
                android:completionThreshold="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Dodaj zdjęcie"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonAddPhoto"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:minHeight="52dp"
                android:text="Aparat"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_camera" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSelectGallery"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:minHeight="52dp"
                android:text="Galeria"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_gallery" />
        </LinearLayout>

        <ImageView
            android:id="@+id/imagePreview"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            tools:visibility="visible"
            tools:src="@tools:sample/backgrounds/scenic" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSubmitIssue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:minHeight="56dp"
            android:text="@string/issue_button_submit"
            android:textSize="18sp"
            app:cornerRadius="12dp" />

        <ProgressBar
            android:id="@+id/progressIssue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
