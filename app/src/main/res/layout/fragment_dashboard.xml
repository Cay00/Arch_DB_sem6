<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp">

    <TextView
        android:id="@+id/textDashboardTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/my_issues_title"
        android:textAppearance="@style/TextAppearance.Urbanfix.Title"
        android:textSize="22sp" />

    <ProgressBar
        android:id="@+id/progressIssues"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/dashboard_content_top_spacing"
        android:visibility="gone" />

    <TextView
        android:id="@+id/textIssuesEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dashboard_content_top_spacing"
        android:text="@string/my_issues_empty"
        android:textAppearance="@style/TextAppearance.Urbanfix.Body"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/issuesScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/dashboard_content_top_spacing"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/issuesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingBottom="@dimen/issue_list_container_padding_bottom" />
    </ScrollView>
</LinearLayout>