<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.home.HomeFragment">

    <TextView
        android:id="@+id/text_home"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:textAlignment="center"
        android:textSize="20sp"
        android:text="@string/home_report_title"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/report_grid"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginVertical="8dp"
        app:layout_constraintTop_toBottomOf="@id/text_home"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Tile 1 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tile_road_damage"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="8dp"
            android:contentDescription="@string/tile_road_damage"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/tile_road_damage_bg"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tile_street_lighting"
            app:layout_constraintBottom_toTopOf="@id/tile_illegal_dumping"
            app:layout_constraintDimensionRatio="1:1">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">
                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:importantForAccessibility="no"
                    android:contentDescription="@null"
                    app:tint="?attr/colorPrimary"
                    android:src="@android:drawable/ic_menu_report_image" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/tile_road_damage"
                    android:textAlignment="center"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"
                    android:maxLines="3"
                    tools:text="Uszkodzenie nawierzchni" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tile 2 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tile_street_lighting"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="8dp"
            android:contentDescription="@string/tile_street_lighting"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/tile_street_lighting_bg"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/tile_road_damage"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tile_vandalism"
            app:layout_constraintDimensionRatio="1:1">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">
                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:importantForAccessibility="no"
                    android:contentDescription="@null"
                    app:tint="?attr/colorPrimary"
                    android:src="@android:drawable/ic_menu_gallery" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/tile_street_lighting"
                    android:textAlignment="center"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"
                    android:maxLines="3"
                    tools:text="Awaria oświetlenia" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tile 3 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tile_illegal_dumping"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="8dp"
            android:contentDescription="@string/tile_illegal_dumping"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/tile_illegal_dumping_bg"
            app:layout_constraintTop_toBottomOf="@id/tile_road_damage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tile_vandalism"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1:1">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">
                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:importantForAccessibility="no"
                    android:contentDescription="@null"
                    app:tint="?attr/colorPrimary"
                    android:src="@android:drawable/ic_menu_delete" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/tile_illegal_dumping"
                    android:textAlignment="center"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"
                    android:maxLines="3"
                    tools:text="Nielegalne wysypisko" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tile 4 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tile_vandalism"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="8dp"
            android:contentDescription="@string/tile_vandalism"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/tile_vandalism_bg"
            app:layout_constraintTop_toBottomOf="@id/tile_street_lighting"
            app:layout_constraintStart_toEndOf="@id/tile_illegal_dumping"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1:1">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">
                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:importantForAccessibility="no"
                    android:contentDescription="@null"
                    app:tint="?attr/colorPrimary"
                    android:src="@android:drawable/ic_menu_edit" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/tile_vandalism"
                    android:textAlignment="center"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"
                    android:maxLines="3"
                    tools:text="Wandalizm" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>