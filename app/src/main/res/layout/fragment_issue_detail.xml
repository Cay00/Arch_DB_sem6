<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="@dimen/issue_detail_screen_padding_v">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/issue_detail_screen_padding_h"
        android:paddingTop="@dimen/issue_detail_screen_padding_v">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_issue_detail"
            style="@style/Widget.Urbanfix.HomeIssueTile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/issue_detail_card_margin_bottom">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/issue_list_card_content_padding_horizontal"
                android:paddingTop="@dimen/issue_list_card_content_padding_top"
                android:paddingBottom="@dimen/issue_list_card_content_padding_bottom">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/image_issue_photo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/issue_detail_image_content_description"
                        android:maxHeight="@dimen/issue_detail_image_max_height"
                        android:scaleType="fitCenter"
                        tools:src="@android:drawable/ic_menu_gallery" />

                    <TextView
                        android:id="@+id/text_issue_photo_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:gravity="center"
                        android:text="@string/issue_detail_photo_placeholder"
                        android:textSize="36sp"
                        tools:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:id="@+id/text_issue_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/issue_detail_section_margin_top"
                    android:background="@drawable/bg_issue_detail_id_chip"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:textAppearance="@style/TextAppearance.Urbanfix.Label"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    tools:text="ID: 12" />

                <TextView
                    android:id="@+id/text_issue_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/issue_detail_title_margin_top"
                    android:textAppearance="@style/TextAppearance.Urbanfix.Title"
                    android:textSize="22sp"
                    tools:text="Tytuł zgłoszenia" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/issue_detail_section_margin_top"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/text_issue_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_issue_tag_category"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:textAppearance="@style/TextAppearance.Urbanfix.Label"
                        android:textStyle="bold"
                        tools:text="Drogi" />

                    <TextView
                        android:id="@+id/text_issue_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_issue_tag_status"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:textAppearance="@style/TextAppearance.Urbanfix.Label"
                        android:textStyle="bold"
                        tools:text="Zgłoszone" />
                </LinearLayout>

                <TextView
                    android:id="@+id/text_issue_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/issue_detail_section_margin_top"
                    android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailValue"
                    tools:text="Opis" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_support_issue"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/issue_detail_section_margin_top"
                    app:cornerRadius="@dimen/home_issue_tile_corner_radius"
                    tools:text="Poprzyj (12)" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/issue_detail_section_margin_top"
                    android:text="@string/issue_detail_label_location"
                    android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailLabel" />

                <TextView
                    android:id="@+id/text_issue_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/issue_detail_label_to_value_gap"
                    android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailValue"
                    tools:text="ul. Przykładowa 1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/issue_detail_section_margin_top"
                    android:text="@string/issue_detail_label_created"
                    android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailLabel" />

                <TextView
                    android:id="@+id/text_issue_created"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/issue_detail_label_to_value_gap"
                    android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailValue"
                    tools:text="2026-01-01" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/issue_detail_section_margin_top"
                    android:text="@string/issue_detail_label_timeline"
                    android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailLabel" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/row_timeline_reported"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/text_timeline_dot_reported"
                            android:layout_width="24dp"
                            android:layout_height="wrap_content"
                            android:text="●"
                            android:textColor="#2E7D32"
                            android:textSize="16sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text_timeline_label_reported"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Zgłoszone"
                                android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailValue" />

                            <TextView
                                android:id="@+id/text_timeline_date_reported"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Urbanfix.BodySecondary"
                                tools:text="2026-04-21 12:45" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/row_timeline_reviewed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/text_timeline_dot_reviewed"
                            android:layout_width="24dp"
                            android:layout_height="wrap_content"
                            android:text="●"
                            android:textSize="16sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text_timeline_label_reviewed"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Rozpatrywane"
                                android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailValue" />

                            <TextView
                                android:id="@+id/text_timeline_date_reviewed"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Urbanfix.BodySecondary"
                                tools:text="2026-04-22 08:10" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/row_timeline_accepted"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/text_timeline_dot_accepted"
                            android:layout_width="24dp"
                            android:layout_height="wrap_content"
                            android:text="●"
                            android:textSize="16sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text_timeline_label_accepted"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Zaakceptowane"
                                android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailValue" />

                            <TextView
                                android:id="@+id/text_timeline_date_accepted"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Urbanfix.BodySecondary"
                                tools:text="2026-04-23 09:30" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/row_timeline_rejected"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/text_timeline_dot_rejected"
                            android:layout_width="24dp"
                            android:layout_height="wrap_content"
                            android:text="●"
                            android:textSize="16sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text_timeline_label_rejected"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Odrzucone"
                                android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailValue" />

                            <TextView
                                android:id="@+id/text_timeline_date_rejected"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Urbanfix.BodySecondary"
                                tools:text="2026-04-23 09:30" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_official_actions"
            style="@style/Widget.Urbanfix.HomeIssueTile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/issue_list_card_content_padding_horizontal"
                android:paddingTop="@dimen/issue_list_card_content_padding_top"
                android:paddingBottom="@dimen/issue_list_card_content_padding_bottom">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/issue_detail_official_section_title"
                    android:textAppearance="@style/TextAppearance.Urbanfix.Subtitle"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/issue_detail_section_margin_top"
                    android:hint="@string/issue_detail_status_hint"
                    app:hintTextAppearance="@style/TextAppearance.Urbanfix.InputHint">

                    <AutoCompleteTextView
                        android:id="@+id/dropdown_issue_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailValue" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_save_status"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/issue_detail_section_margin_top"
                    android:text="@string/issue_detail_save_status"
                    app:cornerRadius="@dimen/home_issue_tile_corner_radius" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
