<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_issue_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailValue"
            tools:text="ID: 1" />

        <TextView
            android:id="@+id/text_issue_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="@style/TextAppearance.Urbanfix.Title"
            android:textSize="24sp"
            tools:text="Tytuł" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/issue_detail_label_description"
            android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailLabel" />

        <TextView
            android:id="@+id/text_issue_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailValue"
            tools:text="Opis" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/issue_detail_label_category"
            android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailLabel" />

        <TextView
            android:id="@+id/text_issue_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailValue"
            tools:text="Drogi" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/issue_detail_label_status"
            android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailLabel" />

        <TextView
            android:id="@+id/text_issue_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailValue"
            tools:text="Zgłoszone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/issue_detail_label_location"
            android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailLabel" />

        <TextView
            android:id="@+id/text_issue_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailValue"
            tools:text="ul. Przykładowa 1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/issue_detail_label_created"
            android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailLabel" />

        <TextView
            android:id="@+id/text_issue_created"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailValue"
            tools:text="2026-01-01" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/issue_detail_label_user_id"
            android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailLabel" />

        <TextView
            android:id="@+id/text_issue_user_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailValue"
            tools:text="5" />

        <LinearLayout
            android:id="@+id/group_official_status_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/issue_detail_status_hint">

                <AutoCompleteTextView
                    android:id="@+id/dropdown_issue_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textAppearance="@style/TextAppearance.Urbanfix.IssueDetailValue" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_save_status"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/issue_detail_save_status" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
