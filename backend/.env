APP_NAME=UrbanFix API
# Use development locally; production requires a non-placeholder JWT_SECRET_KEY (see config validator).
ENV=development
DEBUG=true

# Optional: when using local Postgres, create user/db to match and set DATABASE_URL below.
POSTGRES_USER=urbanfix
POSTGRES_PASSWORD=urbanfix_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=urbanfix

# File urbanfix.db is created next to the backend working directory (run uvicorn from backend/).
DATABASE_URL=sqlite:///./urbanfix.db
# DATABASE_URL=postgresql+psycopg://urbanfix:urbanfix_password@localhost:5432/urbanfix

JWT_SECRET_KEY=change-me-super-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
